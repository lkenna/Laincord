<Window x:Class="Laincord.Windows.UserProfile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Laincord.Windows"
        xmlns:controls="clr-namespace:Laincord.Controls"
        xmlns:helpers="clr-namespace:Laincord.Helpers"
        mc:Ignorable="d"
        Title="User Profile" Height="480" Width="400"
        ResizeMode="NoResize"
        Style="{StaticResource Window}" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <helpers:ImageConverter x:Key="imageConverter" />
    </Window.Resources>
    <controls:BaseTitlebar BlackText="Black">
        <Grid>
            <Grid.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <LinearGradientBrush.GradientStops>
                        <GradientStop Offset="0" Color="#f1f6fb" />
                        <GradientStop Offset="1" Color="#e5eef8" />
                    </LinearGradientBrush.GradientStops>
                </LinearGradientBrush>
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,14">
                    <!-- Profile picture centered -->
                    <controls:ProfilePictureFrame
                        x:Name="PART_ProfilePicture"
                        HorizontalAlignment="Center"
                        FrameSize="ExtraLarge"
                        Margin="0,0,0,12" />

                    <!-- Display name and username centered -->
                    <TextBlock x:Name="PART_DisplayName" FontSize="20" FontWeight="Bold" Foreground="#355a88" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="PART_Username" FontSize="12" Foreground="#888888" HorizontalAlignment="Center" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />

                    <!-- Status and activity -->
                    <TextBlock x:Name="PART_Status" FontSize="12" Foreground="#333333" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap" />
                    <TextBlock x:Name="PART_Activity" FontSize="11" Foreground="#888888" HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap" />

                    <Separator Margin="0,12,0,12" />

                    <!-- Account Info -->
                    <TextBlock Text="Account Info" FontSize="12" FontWeight="Bold" Foreground="#355a88" Margin="0,0,0,6" />
                    <TextBlock x:Name="PART_CreatedAt" FontSize="11" Foreground="#555555" Margin="0,2,0,0" />
                    <TextBlock x:Name="PART_JoinedAt" FontSize="11" Foreground="#555555" Margin="0,2,0,0" />
                    <TextBlock x:Name="PART_UserId" FontSize="11" Foreground="#555555" Margin="0,2,0,0" />

                    <!-- Roles section -->
                    <TextBlock x:Name="PART_RolesHeader" Text="Roles" FontSize="12" FontWeight="Bold" Foreground="#355a88" Margin="0,14,0,6" Visibility="Collapsed" />
                    <ItemsControl x:Name="PART_Roles" Visibility="Collapsed">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#e8eef7" BorderBrush="#b8c8e0" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,4,4">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="10" Height="10" Margin="0,0,5,0">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding Color}" />
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="#333333" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Margin="16,10" HorizontalAlignment="Right" Grid.Row="1" Orientation="Horizontal">
                <Button Click="SendMessage_Click" MinWidth="90" Height="23" Content="Send Message" Margin="0,0,8,0" />
                <Button Click="Close_Click" MinWidth="72" Height="23" Content="Close" />
            </StackPanel>
        </Grid>
    </controls:BaseTitlebar>
</Window>
